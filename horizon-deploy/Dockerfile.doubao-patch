FROM horizon-reader/horizon:latest

RUN python -c "from pathlib import Path; p = Path('/app/src/ai/client.py'); s = p.read_text(); old = '_NO_RESPONSE_FORMAT = {\"minimax\"}'; new = '_NO_RESPONSE_FORMAT = {\"minimax\", \"doubao\"}'; assert old in s, 'expected response_format provider set not found'; p.write_text(s.replace(old, new))"
