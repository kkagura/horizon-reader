# Horizon environment variables.
# Copy this file to /opt/horizon-deploy/.env and fill in real values on the server.

# Configure the Doubao / Volcengine Ark API key.
DOUBAO_API_KEY=

# Other optional AI providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
MINIMAX_API_KEY=
DASHSCOPE_API_KEY=

# Optional: GitHub token for higher rate limits.
GITHUB_TOKEN=

# Optional: required if Twitter/X scraping is enabled.
APIFY_TOKEN=

# Optional: webhook delivery.
HORIZON_WEBHOOK_URL=
